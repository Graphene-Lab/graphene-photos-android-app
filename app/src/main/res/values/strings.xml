    <!-- OAuth Zero-Knowledge Setup Screen -->
    <string name="oauth_zk_setup_title">Zero-Knowledge Setup</string>
    <string name="oauth_zk_setup_subtitle">Finalize your account pairing by enabling Zero-Knowledge Encryption.</string>
    <string name="oauth_zk_security_cd">Security details</string>
    <string name="oauth_zk_how_works_title">How Zero-Knowledge Works</string>
    <string name="oauth_zk_how_works_body">Your files are encrypted locally on your device before they are sent to our servers, ensuring only you can access your data; our servers never see it.\n\nYour passphrase derives a master key. From that master key, the app derives a unique encryption key for each file using the file name and file timestamp. This means files are not encrypted with one static key, which provides stronger isolation.</string>
