    <!-- OAuth Zero-Knowledge Setup Screen -->
    <string name="oauth_zk_setup_title">Zero-Knowledge Setup</string>
    <string name="oauth_zk_setup_subtitle">Finalisez le jumelage de votre compte en activant Zero-Knowledge Encryption.</string>
    <string name="oauth_zk_security_cd">Détails de sécurité</string>
    <string name="oauth_zk_how_works_title">How Zero-Knowledge Works</string>
    <string name="oauth_zk_how_works_body">Vos fichiers sont chiffrés localement sur votre appareil avant d\'être envoyés à nos serveurs, garantissant que seul vous pouvez accéder à vos données ; nos serveurs ne les voient jamais.\n\nVotre phrase secrète dérive une clé maître. À partir de cette clé maître, l\'application dérive une clé de chiffrement unique pour chaque fichier en utilisant le nom et l\'horodatage du fichier. Cela signifie que les fichiers ne sont pas chiffrés avec une seule clé statique, ce qui offre une isolation plus forte.</string>
    <string name="oauth_zk_first_signin">C\'est ma première connexion</string>
    <string name="oauth_zk_choose_passphrase">Choisissez comment configurer la phrase secrète :</string>
    <string name="oauth_zk_generated_passphrase_label">Phrase secrète générée (24 mots) :</string>
    <string name="oauth_zk_regenerate_cd">Régénérer la phrase secrète</string>
    <string name="oauth_zk_copy_passphrase_cd">Copier la phrase secrète</string>
    <string name="oauth_zk_passphrase_copied">Phrase secrète copiée</string>
    <string name="oauth_zk_save_passphrase_warning">Important : sauvegardez cette phrase secrète en lieu sûr.</string>
    <string name="oauth_zk_warning_cd">Détails de l\'avertissement sur la phrase secrète</string>
    <string name="oauth_zk_passphrase_warning_title">Avertissement sur la phrase secrète</string>
    <string name="oauth_zk_passphrase_warning_body">Ne perdez pas cette phrase secrète. Sauvegardez-la dans un endroit sécurisé. Si vous la perdez, vous pouvez perdre l\'accès à vos fichiers chiffrés. Cette phrase secrète n\'est pas stockée sur nos serveurs.</string>
    <string name="oauth_zk_own_passphrase_label">Votre phrase secrète</string>
