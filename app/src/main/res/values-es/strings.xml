    <!-- OAuth Zero-Knowledge Setup Screen -->
    <string name="oauth_zk_setup_title">Zero-Knowledge Setup</string>
    <string name="oauth_zk_setup_subtitle">Finaliza el emparejamiento de tu cuenta habilitando Zero-Knowledge Encryption.</string>
    <string name="oauth_zk_security_cd">Detalles de seguridad</string>
    <string name="oauth_zk_how_works_title">How Zero-Knowledge Works</string>
    <string name="oauth_zk_how_works_body">Tus archivos se cifran localmente en tu dispositivo antes de enviarse a nuestros servidores, garantizando que solo tú puedes acceder a tus datos; nuestros servidores nunca los ven.\n\nTu frase de contraseña deriva una clave maestra. A partir de esa clave maestra, la aplicación deriva una clave de cifrado única para cada archivo usando el nombre del archivo y la marca de tiempo. Esto significa que los archivos no se cifran con una única clave estática, lo que proporciona un aislamiento más sólido.</string>
    <string name="oauth_zk_first_signin">Es mi primer inicio de sesión</string>
    <string name="oauth_zk_choose_passphrase">Elige cómo configurar la frase de contraseña:</string>
    <string name="oauth_zk_generated_passphrase_label">Frase de contraseña generada (24 palabras):</string>
    <string name="oauth_zk_regenerate_cd">Regenerar frase de contraseña</string>
    <string name="oauth_zk_copy_passphrase_cd">Copiar frase de contraseña</string>
    <string name="oauth_zk_passphrase_copied">Frase de contraseña copiada</string>
    <string name="oauth_zk_save_passphrase_warning">Importante: guarda esta frase de contraseña en un lugar seguro.</string>
    <string name="oauth_zk_warning_cd">Detalles de advertencia de la frase de contraseña</string>
    <string name="oauth_zk_passphrase_warning_title">Advertencia de frase de contraseña</string>
    <string name="oauth_zk_passphrase_warning_body">No pierdas esta frase de contraseña. Guárdala en un lugar seguro. Si la pierdes, puedes perder el acceso a tus archivos cifrados. Esta frase de contraseña no se almacena en nuestros servidores.</string>
    <string name="oauth_zk_own_passphrase_label">Tu frase de contraseña</string>
    <string name="oauth_zk_own_passphrase_placeholder">Introduce una frase de contraseña de 12 o 24 palabras</string>
